{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Plot Server (headless)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/plot_run.py",
            "python": "/home/Creeken/miniconda3/envs/pytorch/bin/python",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": true,
            "args": [
                "--host",
                "127.0.0.1",
                "--port",
                "9000",
                "--headless",
                "--save-path",
                "debug_loss.png"
            ]
        },
        {
            "name": "Plot Server (window)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/plot_run.py",
            "python": "/home/Creeken/miniconda3/envs/pytorch/bin/python",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": true,
            "args": [
                "--host",
                "127.0.0.1",
                "--port",
                "9000"
            ]
        },
        {
            "name": "Train Client",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/train_run.py",
            "python": "/home/Creeken/miniconda3/envs/pytorch/bin/python",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": true,
            "args": [
                "--host",
                "127.0.0.1",
                "--port",
                "9000",
                "--epochs",
                "8",
                "--interval",
                "0.5"
            ]
        }
    ],
    "compounds": [
        {
            "name": "TCP Demo (headless + train)",
            "configurations": [
                "Plot Server (headless)",
                "Train Client"
            ],
            "stopAll": true
        }
    ]
}
